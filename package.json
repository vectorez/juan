{
  "name": "csv-uploader",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n BACK,FRONT -c cyan,magenta \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "dev:backend": "pnpm --prefix backend dev",
    "dev:frontend": "pnpm --prefix frontend dev",
    "build": "pnpm --prefix frontend build",
    "start": "pnpm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
