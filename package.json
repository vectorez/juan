{
  "name": "csv-uploader",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n BACK,FRONT -c cyan,magenta \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && node_modules/.bin/tsx watch src/index.ts",
    "dev:frontend": "cd frontend && node_modules/.bin/vite",
    "build": "cd frontend && npm run build",
    "start": "npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
